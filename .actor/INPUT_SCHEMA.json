{
  "title": "European Electricity Price Monitor",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "countries": {
      "title": "Countries to Monitor",
      "type": "array",
      "description": "Country codes: DE, FR, AT, HU, CZ, SK, RO, PL, IT, ES, NL, BE, CH, SI, HR",
      "editor": "stringList",
      "default": ["DE", "FR", "AT", "HU", "CZ", "SK", "RO", "PL", "IT", "ES", "NL", "BE", "CH", "SI", "HR"]
    },
    "priceThreshold": {
      "title": "Price Alert Threshold (EUR/MWh)",
      "type": "integer",
      "description": "Alert if any country exceeds this",
      "default": 200,
      "minimum": 0,
      "maximum": 1000
    },
    "emailTo": {
      "title": "Alert Email To",
      "type": "string",
      "editor": "textfield"
    },
    "emailFrom": {
      "title": "Alert Email From (optional)",
      "type": "string",
      "editor": "textfield"
    },
    "gmailUser": {
      "title": "Gmail Username",
      "type": "string",
      "editor": "textfield"
    },
    "gmailPass": {
      "title": "Gmail App Password",
      "type": "string",
      "editor": "textfield",
      "isSecret": true
    }
  },
  "required": []
}
